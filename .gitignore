# Task database + seed files (runtime state lives in Supabase)
.pm/tasks.db
.pm/todo/**/tasks.sql

# Working memory (transitory scratch files)
.wm/

# Agent worktrees (created by coordination system)
.worktrees/

# Merge conflict reports
.pm/conflicts/

# Sync backups
.n2o-backup/

# Project registry (local to your machine)
.n2o-projects.json

# Obsidian
.obsidian/

# OS files
.DS_Store

# Per-developer state
.pm/.last_seen_version

# Dependencies
node_modules/
package.json
package-lock.json

# Environment
.env
.env.local
.env.*.local

# SQLite WAL/SHM (transient database files)
*.db-shm
*.db-wal
